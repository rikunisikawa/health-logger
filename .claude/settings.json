{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform init *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform validate *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform fmt *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform plan *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform output *)",
      "Bash(aws *)",
      "Bash(cd * && *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force *)",
      "Bash(aws * create-*)",
      "Bash(aws * delete-*)",
      "Bash(aws * remove-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws * destroy-*)",
      "Bash(aws * run-instances*)",
      "Bash(aws * run-task*)",
      "Bash(aws s3 cp *)",
      "Bash(aws s3 mv *)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 sync *)"
    ]
  },
  "enabledMcpjsonServers": [
    "filesystem",
    "github",
    "aws",
    "terraform",
    "git",
    "fetch",
    "mermaid",
    "drawio"
  ]
}
