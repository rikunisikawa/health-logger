{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform init *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform validate *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform fmt *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform plan *)",
      "Bash(docker compose -f docker-compose.terraform.yml run --rm terraform output *)",
      "Bash(aws *)",
      "Bash(cd * && *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force *)",
      "Bash(aws * create-*)",
      "Bash(aws * delete-*)",
      "Bash(aws * remove-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws * destroy-*)",
      "Bash(aws * run-instances*)",
      "Bash(aws * run-task*)",
      "Bash(aws s3 cp *)",
      "Bash(aws s3 mv *)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 sync *)",
      "Bash(docker compose * terraform apply*)",
      "Bash(docker compose * terraform destroy*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enabledMcpjsonServers": [
    "filesystem",
    "github",
    "aws",
    "terraform",
    "git",
    "fetch",
    "mermaid",
    "drawio"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/block-forbidden-dirs.py",
            "description": "app/ と terraform/envs/dev/ への書き込みをブロック"
          },
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/warn-critical-file-edit.py",
            "description": "CLAUDE.md/settings.json/hooks 変更時に警告"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/git-push-reminder.py",
            "description": "git push 前にシークレット漏洩・CI 確認を促す"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/run-tests-after-edit.py",
            "description": "lambda/ 実装 .py 変更後に pytest を自動実行"
          },
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/format-lint-on-edit.py",
            "description": "Python(ruff) / TypeScript(eslint+prettier) の自動フォーマット"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/load-context-on-start.py",
            "description": "セッション開始時にスプリント状態・open Issue をコンテキストロード（初回のみ）"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/riku_nishikawa/dev/health-logger/health-logger/.claude/hooks/log-prompt.py",
            "description": "プロンプトごとのログを .claude/logs/YYYY-MM-DD/HHMMSS.md に保存する"
          }
        ]
      }
    ]
  }
}
