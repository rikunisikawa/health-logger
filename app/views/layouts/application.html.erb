<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "Health Logger" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="Health Logger">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#198754">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Bootstrap 5 CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-dark bg-success">
      <div class="container">
        <span class="navbar-brand fw-bold">
          <i class="bi bi-heart-pulse-fill"></i> Health Logger
        </span>
        <span class="text-white-50 small"><%= ENV.fetch("AUTH_USERNAME", "admin") %></span>
      </div>
    </nav>

    <%# Flash messages as Bootstrap alerts %>
    <% if flash[:notice] %>
      <div id="flash-notice" class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
        <i class="bi bi-check-circle-fill"></i> <%= flash[:notice] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> <%= flash[:alert] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <%# Offline banner %>
    <div id="offline-banner" class="alert alert-warning m-0 rounded-0 text-center py-1 d-none" role="alert">
      <i class="bi bi-wifi-off"></i> オフライン中 — 記録はローカルに保存され、オンライン復帰時に送信されます
    </div>

    <main class="container py-4">
      <%= yield %>
    </main>

    <%# Bootstrap 5 JS %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <%# Service Worker registration %>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(console.error);
      }

      // Offline detection
      function updateOnlineStatus() {
        document.getElementById('offline-banner')?.classList.toggle('d-none', navigator.onLine);
      }
      window.addEventListener('online', updateOnlineStatus);
      window.addEventListener('offline', updateOnlineStatus);
      updateOnlineStatus();
    </script>

    <%= yield :scripts %>
  </body>
</html>
