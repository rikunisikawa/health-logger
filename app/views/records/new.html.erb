<% content_for :title, "今日の体調を記録" %>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">

    <%# Install banner (shown once) %>
    <div id="install-banner" class="alert alert-info alert-dismissible fade show d-none mb-3" role="alert">
      <i class="bi bi-phone"></i>
      <strong>ホーム画面に追加</strong>できます！ブラウザのメニューから「ホーム画面に追加」を選択してください。
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <div class="card shadow-sm">
      <div class="card-header bg-success text-white">
        <h5 class="mb-0">
          <i class="bi bi-clipboard2-pulse"></i>
          今日の体調記録
          <small class="fw-normal ms-2 opacity-75"><%= Time.current.strftime("%Y年%m月%d日") %></small>
        </h5>
      </div>

      <div class="card-body">
        <%= form_with model: @record, url: records_path, id: "health-form", data: { offline_form: true } do |f| %>

          <%= f.hidden_field :timezone, value: "", id: "timezone-field" %>
          <%= f.hidden_field :device_id, value: "", id: "device-id-field" %>
          <%= f.hidden_field :app_version, value: "1.0.0" %>

          <%# Fatigue Score %>
          <div class="mb-4">
            <label class="form-label fw-semibold">
              <i class="bi bi-battery-half text-danger"></i>
              疲労度
              <span id="fatigue-val" class="badge bg-danger ms-2">50</span>
            </label>
            <%= f.range_field :fatigue_score, min: 0, max: 100, value: 50,
                class: "form-range",
                id: "fatigue-slider",
                oninput: "updateBadge('fatigue-val', this.value)" %>
            <div class="d-flex justify-content-between small text-muted">
              <span>元気 0</span><span>100 疲弊</span>
            </div>
          </div>

          <%# Mood Score %>
          <div class="mb-4">
            <label class="form-label fw-semibold">
              <i class="bi bi-emoji-smile text-warning"></i>
              気分
              <span id="mood-val" class="badge bg-warning text-dark ms-2">50</span>
            </label>
            <%= f.range_field :mood_score, min: 0, max: 100, value: 50,
                class: "form-range",
                id: "mood-slider",
                oninput: "updateBadge('mood-val', this.value)" %>
            <div class="d-flex justify-content-between small text-muted">
              <span>最悪 0</span><span>100 最高</span>
            </div>
          </div>

          <%# Motivation Score %>
          <div class="mb-4">
            <label class="form-label fw-semibold">
              <i class="bi bi-lightning-charge text-primary"></i>
              やる気
              <span id="motivation-val" class="badge bg-primary ms-2">50</span>
            </label>
            <%= f.range_field :motivation_score, min: 0, max: 100, value: 50,
                class: "form-range",
                id: "motivation-slider",
                oninput: "updateBadge('motivation-val', this.value)" %>
            <div class="d-flex justify-content-between small text-muted">
              <span>なし 0</span><span>100 全開</span>
            </div>
          </div>

          <%# Flags (checkboxes) %>
          <div class="mb-4">
            <label class="form-label fw-semibold">
              <i class="bi bi-tags"></i> 今日の状態
            </label>
            <div class="row g-2">
              <% [
                { bit: 1,  icon: "bi-moon-stars",       label: "睡眠不足",  color: "secondary" },
                { bit: 2,  icon: "bi-emoji-dizzy",      label: "頭痛",      color: "danger" },
                { bit: 4,  icon: "bi-thermometer-half", label: "腹痛",      color: "warning" },
                { bit: 8,  icon: "bi-bicycle",          label: "運動した",  color: "success" },
                { bit: 16, icon: "bi-cup-straw",        label: "飲酒",      color: "info" },
                { bit: 32, icon: "bi-cup-hot",          label: "カフェイン", color: "dark" }
              ].each do |flag| %>
                <div class="col-6 col-sm-4">
                  <div class="form-check">
                    <input class="form-check-input flag-checkbox"
                           type="checkbox"
                           data-bit="<%= flag[:bit] %>"
                           id="flag-<%= flag[:bit] %>"
                           onchange="updateFlags()">
                    <label class="form-check-label" for="flag-<%= flag[:bit] %>">
                      <i class="bi <%= flag[:icon] %> text-<%= flag[:color] %>"></i>
                      <%= flag[:label] %>
                    </label>
                  </div>
                </div>
              <% end %>
            </div>
            <%= f.hidden_field :flags, value: 0, id: "flags-field" %>
          </div>

          <%# Note %>
          <div class="mb-4">
            <label class="form-label fw-semibold">
              <i class="bi bi-pencil"></i> メモ
              <span class="text-muted fw-normal small">（最大280文字）</span>
            </label>
            <%= f.text_area :note, rows: 3, class: "form-control",
                placeholder: "今日の体調について...",
                maxlength: 280,
                oninput: "updateCharCount(this)" %>
            <div class="text-end small text-muted mt-1">
              <span id="char-count">0</span>/280
            </div>
          </div>

          <%# Submit %>
          <div class="d-grid">
            <%= f.submit "記録する", class: "btn btn-success btn-lg", id: "submit-btn" %>
          </div>

        <% end %>
      </div>
    </div>

    <%# Success Toast %>
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
      <div id="success-toast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
          <div class="toast-body">
            <i class="bi bi-check-circle-fill"></i> 記録を保存しました！
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
      </div>
    </div>

  </div>
</div>

<% content_for :scripts do %>
<script>
  document.getElementById('timezone-field').value = Intl.DateTimeFormat().resolvedOptions().timeZone;
  document.getElementById('device-id-field').value = getDeviceId();

  function getDeviceId() {
    let id = localStorage.getItem('health_logger_device_id');
    if (!id) {
      id = 'dev_' + Math.random().toString(36).slice(2, 11);
      localStorage.setItem('health_logger_device_id', id);
    }
    return id;
  }

  function updateBadge(badgeId, value) {
    document.getElementById(badgeId).textContent = value;
  }

  function updateFlags() {
    let flags = 0;
    document.querySelectorAll('.flag-checkbox:checked').forEach(cb => {
      flags |= parseInt(cb.dataset.bit);
    });
    document.getElementById('flags-field').value = flags;
  }

  function updateCharCount(el) {
    document.getElementById('char-count').textContent = el.value.length;
  }

  if (!localStorage.getItem('install_banner_dismissed')) {
    const banner = document.getElementById('install-banner');
    if (banner) {
      banner.classList.remove('d-none');
      banner.addEventListener('closed.bs.alert', () => {
        localStorage.setItem('install_banner_dismissed', '1');
      });
    }
  }

  <% if flash[:notice] %>
    const toastEl = document.getElementById('success-toast');
    if (toastEl) new bootstrap.Toast(toastEl, { delay: 3000 }).show();
  <% end %>
</script>
<% end %>
